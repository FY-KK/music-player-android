{
  "name": "mineradio-android",
  "version": "1.0.0",
  "description": "Mineradio Android - Capacitor + WebView",
  "main": "index.js",
  "scripts": {
    "build": "echo 'Build complete'",
    "cap:init": "npx cap init mineradio-android com.mineradio.app --web-dir src/main/assets/www",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  }
}
